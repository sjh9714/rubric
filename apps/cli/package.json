{
  "name": "@rubric-dev/cli",
  "version": "0.0.0",
  "private": true,
  "description": "CLI for rubric preflight checks.",
  "type": "module",
  "bin": {
    "rubric": "dist/index.js"
  },
  "exports": {
    "./program": {
      "types": "./dist/program.d.ts",
      "import": "./dist/program.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/program.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run tests"
  },
  "dependencies": {
    "commander": "^15.0.0"
  }
}
