{
  "name": "@rubric-dev/cli",
  "version": "0.3.0",
  "description": "Team review memory CLI for AI-assisted development.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sjh9714/rubric.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/sjh9714/rubric/issues"
  },
  "homepage": "https://github.com/sjh9714/rubric#readme",
  "keywords": [
    "rubric",
    "cli",
    "pull-request",
    "ai",
    "code-review"
  ],
  "type": "module",
  "bin": {
    "rubric": "dist/index.js"
  },
  "exports": {
    "./program": {
      "types": "./dist/program.d.ts",
      "import": "./dist/program.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/program.ts --format esm --dts --clean",
    "dev": "tsx --conditions=development src/index.ts",
    "test": "vitest run tests"
  },
  "dependencies": {
    "@rubric-dev/compiler": "workspace:^",
    "@rubric-dev/core": "workspace:^",
    "@rubric-dev/packs": "workspace:^",
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  }
}
